# ── Application ──────────────────────────────────────────────
APP_NAME=VoidFill
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=voidfill
POSTGRES_PASSWORD=voidfill_secret
POSTGRES_DB=voidfill

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Auth ────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── AI / Embeddings ────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Voice ───────────────────────────────────────────────────
VOICE_UPLOAD_DIR=/tmp/voidfill_voice
MAX_VOICE_FILE_SIZE_MB=25

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
