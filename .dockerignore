# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Environment & secrets (NEVER bake into image) ────────────────────────────
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
backend/.venv/
backend/venv/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/.next/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Tests & coverage ─────────────────────────────────────────────────────────
backend/tests/
*.test.*
coverage/
.coverage
htmlcov/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker ───────────────────────────────────────────────────────────────────
Dockerfile*
docker-compose*.yml
.dockerignore

# ── Misc ─────────────────────────────────────────────────────────────────────
*.md
*.log
tmp/
temp/
